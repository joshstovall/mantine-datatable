{
  "name": "@joshstovall/mantine-datatable",
  "version": "9.0.0",
  "description": "Community fork of mantine-datatable, updated for Mantine v9 with declarative column filters and opt-in row/column virtualization. The lightweight, dependency-free, dark-theme aware table component for Mantine UI data-rich applications, featuring asynchronous data loading, pagination, intuitive Gmail-style additive batch rows selection, column sorting, custom cell rendering, row expansion, nesting, context menus, and more.",
  "keywords": [
    "mantine",
    "mantine-v9",
    "data",
    "table",
    "grid",
    "datatable",
    "datagrid",
    "data table",
    "data grid",
    "async",
    "nested",
    "sorting",
    "pagination",
    "context menu",
    "filters",
    "virtualization",
    "react",
    "react-19",
    "component",
    "react server components",
    "typescript",
    "ui",
    "user interface",
    "ux",
    "user experience"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/joshstovall/mantine-datatable.git"
  },
  "homepage": "https://github.com/joshstovall/mantine-datatable#readme",
  "bugs": {
    "url": "https://github.com/joshstovall/mantine-datatable/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Joshua Stovall",
    "url": "https://github.com/joshstovall"
  },
  "contributors": [
    {
      "name": "Ionut-Cristian Florescu",
      "email": "ionut.florescu@gmail.com",
      "url": "https://github.com/icflorescu"
    }
  ],
  "files": [
    "./dist",
    "./README.md",
    "./LICENSE"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./styles.css": "./dist/styles.css",
    "./styles.layer.css": "./dist/styles.layer.css"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build:package": "rm -rf dist; tsup --config scripts/tsup.esm.ts; tsup --config scripts/tsup.cjs.ts; tsup --config scripts/tsup.dts.ts; postcss package/styles*.css --dir dist",
    "build:docs": "next build",
    "build": "pnpm build:package && pnpm build:docs",
    "lint": "eslint . && tsc --noEmit --pretty",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@docsearch/css": "^4.6.3",
    "@docsearch/react": "^4.6.3",
    "@eslint/eslintrc": "^3.3.5",
    "@faker-js/faker": "^10.4.0",
    "@formkit/auto-animate": "^0.9.0",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/code-highlight": "^9.1.1",
    "@mantine/core": "^9.1.1",
    "@mantine/dates": "^9.1.1",
    "@mantine/hooks": "^9.1.1",
    "@mantine/modals": "^9.1.1",
    "@mantine/notifications": "^9.1.1",
    "@next/eslint-plugin-next": "^16.2.4",
    "@tabler/icons-react": "^3.41.1",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/lodash": "^4.17.24",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "clsx": "^2.1.1",
    "cssnano": "^7.1.8",
    "dayjs": "^1.11.20",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "lodash": "^4.18.1",
    "mantine-contextmenu": "^8.3.13",
    "next": "^16.2.4",
    "postcss": "^8.5.13",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^16.1.1",
    "postcss-preset-mantine": "^1.18.0",
    "postcss-simple-vars": "^7.0.1",
    "prettier": "^3.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "sharp": "^0.34.5",
    "shiki": "^4.0.2",
    "swr": "^2.4.1",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@mantine/core": ">=9.1.1",
    "@mantine/dates": ">=9.1.1",
    "@mantine/hooks": ">=9.1.1",
    "@tanstack/react-virtual": ">=3.10.0",
    "clsx": ">=2",
    "react": ">=19",
    "react-dom": ">=19"
  },
  "peerDependenciesMeta": {
    "@mantine/dates": {
      "optional": true
    },
    "@tanstack/react-virtual": {
      "optional": true
    }
  }
}
